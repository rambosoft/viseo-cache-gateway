# Runtime
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Core infrastructure
REDIS_URL=redis://127.0.0.1:6379
REDIS_KEY_PREFIX=cg

# Primary server contract
PRIMARY_SERVER_URL=http://127.0.0.1:4000
PRIMARY_SERVER_VALIDATE_PATH=/validate
UPSTREAM_TIMEOUT_MS=5000

# Revision and queue behavior
PLAYLIST_REVISION_STALE_AFTER_MS=300000
REVISION_RETAIN_COUNT=2
BULLMQ_PREFIX=cg:jobs
PLAYLIST_REVISION_QUEUE_NAME=playlist-revision
PLAYLIST_REVISION_WORKER_CONCURRENCY=2
PLAYLIST_REVISION_WORKER_HEARTBEAT_INTERVAL_MS=5000
PLAYLIST_REVISION_WORKER_HEARTBEAT_STALE_AFTER_MS=15000

# Profiling
ENABLE_EVENT_LOOP_PROFILING=false
EVENT_LOOP_PROFILING_INTERVAL_MS=30000

# Manual fixture defaults
MANUAL_FIXTURE_SOURCE_TYPE=m3u
MANUAL_FIXTURE_PRIMARY_PORT=4000
MANUAL_FIXTURE_SOURCE_PORT=5000
MANUAL_FIXTURE_BIND_HOST=127.0.0.1
MANUAL_FIXTURE_ADVERTISED_HOST=127.0.0.1
MANUAL_FIXTURE_PLAYLIST_ID=pl_demo
MANUAL_FIXTURE_PLAYLIST_NAME=Demo Playlist
MANUAL_FIXTURE_TOKEN=demo-token
