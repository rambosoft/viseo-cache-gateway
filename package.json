                         "pino":  "^10.0.0",
                         "zod":  "^4.1.5"
                     },
    "devDependencies":  {
                            "@swc/cli":  "^0.7.8",
                            "@swc/core":  "^1.13.5",
                            "@types/express":  "^5.0.3",
                            "@types/node":  "^24.5.2",
                            "@types/supertest":  "^6.0.3",
                            "ioredis-mock":  "^8.13.0",
                            "supertest":  "^7.1.4",
                            "tsx":  "^4.20.5",
                            "typescript":  "^5.9.2",
                            "vitest":  "^3.2.4"
                        }
}

