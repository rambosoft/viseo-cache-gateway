{
    "name":  "cache_gateway",
    "version":  "0.1.0",
    "private":  true,
    "description":  "Multi-tenant metadata caching and indexing gateway",
    "engines":  {
                    "node":  "\u003e=22.20.0"
                },
    "scripts":  {
                    "dev":  "tsx watch src/bootstrap/server.ts",
                    "build":  "swc src -d dist --copy-files",
