{
  "name": "cache_gateway",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-tenant metadata caching and indexing gateway",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "tsx watch src/bootstrap/server.ts",
    "worker": "tsx watch src/bootstrap/worker.ts",
    "build": "swc src -d dist --copy-files",
    "start:server": "node dist/src/bootstrap/server.js",
    "start:worker": "node dist/src/bootstrap/worker.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:performance": "vitest run --config vitest.performance.config.ts",
    "verify": "npm run typecheck && npm run test"
  },
  "dependencies": {
    "bullmq": "^5.71.0",
    "express": "^5.1.0",
    "ioredis": "^5.8.1",
    "pino": "^10.0.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@swc/cli": "^0.7.8",
    "@swc/core": "^1.13.5",
    "@types/express": "^5.0.3",
    "@types/node": "^24.5.2",
    "@types/supertest": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.8",
    "ioredis-mock": "^8.13.0",
    "supertest": "^7.1.4",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
